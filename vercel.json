{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "PT" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "BR" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "AO" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "MZ" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "CV" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "GW" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "ST" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "TL" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "GQ" }],
      "destination": "/pt",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/pt/contacto", "destination": "/pt/contacto.html" },
    { "source": "/pt/financiamento", "destination": "/pt/financiamento.html" },
    { "source": "/pt/privacidade", "destination": "/pt/privacidade.html" },
    { "source": "/pt/sobre", "destination": "/pt/sobre.html" },
    { "source": "/pt/termos", "destination": "/pt/termos.html" },
    { "source": "/en/about", "destination": "/en/about.html" },
    { "source": "/en/contact", "destination": "/en/contact.html" },
    { "source": "/en/financing", "destination": "/en/financing.html" },
    { "source": "/en/privacy", "destination": "/en/privacy.html" },
    { "source": "/en/terms", "destination": "/en/terms.html" }
  ]
}
